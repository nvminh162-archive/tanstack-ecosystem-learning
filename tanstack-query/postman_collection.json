              "variable": [
                {
                  "key": "postId",
                  "value": "{{postId}}",
                  "description": "ID bài viết cần like."
                }
              ]
            },
            "description": "Cập nhật liked=true. API có cố ý lỗi ngẫu nhiên 25% để demo rollback."
