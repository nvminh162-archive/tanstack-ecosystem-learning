              "variable": [
                {
                  "key": "postId",
                  "value": "{{postId}}",
                  "description": "ID bài viết cần lấy."
                }
              ]
            },
            "description": "Lấy chi tiết một bài viết theo id. Nếu không tồn tại, API trả 404."
