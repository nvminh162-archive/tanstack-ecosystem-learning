{
  "info": {
    "_postman_id": "c8d8d6d2-4b9d-4cb7-9d0d-tanstack-query-demo",
    "name": "TanStack Query Mock API",
    "description": "Postman collection để test các API mock trong Next.js App Router tại app/api/posts.",
