      "item": [
        {
          "name": "GET /api/posts - Lấy danh sách mặc định",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"]
            },
            "description": "Lấy danh sách bài viết với phân trang mặc định: page=1, limit=10."
          },
          "response": []
        },
        {
          "name": "GET /api/posts?page=1&_limit=10 - Lấy danh sách có phân trang",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts?page=1&_limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Trang hiện tại."
                },
                {
                  "key": "_limit",
                  "value": "10",
                  "description": "Số bài viết mỗi trang."
                }
              ]
            },
            "description": "API cũng hỗ trợ _page/_limit hoặc page/limit."
          },
          "response": []
        },
        {
          "name": "POST /api/posts - Tạo bài viết mới",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bài viết tạo từ Postman\",\n  \"body\": \"Đây là nội dung test request POST từ Postman.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"]
            },
            "description": "Tạo bài viết mới. Response trả về bài viết vừa tạo với status 201."
          },
          "response": []
        },
        {
          "name": "POST /api/posts - Tạo bài viết không truyền body",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bài viết chỉ có title\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"]
            },
            "description": "Test case body optional. API sẽ tự dùng body mặc định: \"Nội dung tuyệt vời\"."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Post Detail",
      "item": [
        {
          "name": "GET /api/posts/:id - Lấy chi tiết bài viết",
          "request": {
            "method": "GET",
            "header": [],
